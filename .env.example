# 智场同语中枢 Agent 环境配置模板
# 复制为 .env 后填写真实密钥；不要把 .env 提交到 Git。

# ------------------------------------------------------------
# 默认模型：DeepSeek V4 Flash
# ------------------------------------------------------------
TONGYU_HERMES_PROVIDER=deepseek
TONGYU_HERMES_MODEL=deepseek-v4-flash
TONGYU_HERMES_LLM=1
TONGYU_HERMES_LLM_TIMEOUT_SEC=45

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 默认关闭 thinking；复杂安全/失败/高优先级场景才提升。
TONGYU_DEEPSEEK_THINKING_DEFAULT=disabled
TONGYU_DEEPSEEK_THINKING_ESCALATION=enabled
TONGYU_DEEPSEEK_REASONING_EFFORT=high

# ------------------------------------------------------------
# 可选模型：Kimi Coding / Kimi
# ------------------------------------------------------------
KIMI_CODE_API_KEY=
KIMI_CODE_API_BASE=https://api.kimi.com/coding/v1
KIMI_CODE_MODEL=kimi-for-coding

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# ------------------------------------------------------------
# UrbanAgents / Hermes runtime
# 默认使用仓库内 third_party/UrbanAgents，无需填写。
# 如果想使用本机另一个 UrbanAgents checkout，再打开下面一行。
# ------------------------------------------------------------
# URBAN_AGENTS_ROOT=D:/path/to/UrbanAgents

# ------------------------------------------------------------
# ABC Square / 真实场地数据，可选
# ------------------------------------------------------------
API_KEY=
API_SECRET=
ABC_SQUARE_BASE_URL=http://58.33.91.82:28002

# ------------------------------------------------------------
# 调试选项
# ------------------------------------------------------------
# 设置为 1 可完全跳过 LLM，使用规则/技能 fallback 跑通闭环。
TONGYU_AGENT_DISABLE_LLM=0
